<%
  now = Time.current
  next_occ = event.next_occurrence
  past = event.end_time < now
  minutes_until = past ? nil : ((next_occ - now) / 60).to_i
  own_event = event.host_user_id == current_user.id

  status_badge = if event.cancelled?
    { label: "Cancelled", classes: "bg-stone/20 text-stone" }
  elsif event.active_now?
    { label: "Live now", classes: "bg-ember text-white" }
  elsif past
    { label: "Past", classes: "bg-stone/10 text-stone" }
  elsif minutes_until < 60
    { label: "Live in #{pluralize(minutes_until, 'minute')}", classes: "bg-ink text-white" }
  elsif minutes_until < 1440
    { label: "Live in #{pluralize((minutes_until / 60.0).round, 'hour')}", classes: "bg-ink text-white" }
  elsif minutes_until < 10_080
    { label: "Live in #{pluralize((minutes_until / 1440.0).ceil, 'day')}", classes: "bg-ink text-white" }
  else
    { label: "Upcoming", classes: "bg-stone/10 text-ink" }
  end

  anon_count = event.anonymous_check_in_count&.count
  auth_count = event.check_ins.size
%>
<tr class="hover:bg-white/30 transition">
  <%# Title %>
  <td class="px-4 py-3">
    <span class="font-medium text-ink"><%= event.title %></span>
    <% if event.weekly? %>
      <span class="ml-1.5 font-mono text-[10px] uppercase tracking-wider text-stone/60 border border-stone/20 px-1.5 py-0.5 rounded">Weekly</span>
    <% end %>
    <p class="text-xs text-stone mt-0.5 sm:hidden">
      <% if event.weekly? %>
        <%= event.next_occurrence.strftime("%A at %-I:%M %p") %>
      <% else %>
        <%= event.start_time.strftime("%b %-d · %-I:%M %p") %>
      <% end %>
    </p>
  </td>

  <%# When %>
  <td class="px-4 py-3 text-stone hidden sm:table-cell whitespace-nowrap">
    <% if event.weekly? %>
      <%= event.next_occurrence.strftime("%A at %-I:%M %p") %>
    <% else %>
      <%= event.start_time.strftime("%a · %b %-d · %-I:%M %p") %>
    <% end %>
  </td>

  <%# Anon check-ins %>
  <td class="px-4 py-3 text-right text-stone hidden md:table-cell">
    <%= past && anon_count ? anon_count : "—" %>
  </td>

  <%# Authenticated check-ins %>
  <td class="px-4 py-3 text-right text-stone hidden md:table-cell">
    <%= past ? auth_count : "—" %>
  </td>

  <%# Status badge %>
  <td class="px-4 py-3">
    <span class="font-mono text-[10px] uppercase tracking-wider px-2 py-1 rounded-full whitespace-nowrap <%= status_badge[:classes] %>">
      <%= status_badge[:label] %>
    </span>
  </td>

  <%# Actions %>
  <td class="px-4 py-3 text-right whitespace-nowrap">
    <% if past && own_event %>
      <%= link_to "View Insights →", host_insights_path(event_slug: event.slug),
            class: "text-sm text-stone hover:text-ink transition" %>
    <% elsif own_event %>
      <%= link_to "Edit", edit_host_event_path(event), class: "text-sm text-stone hover:text-ink transition" %>
    <% else %>
      <%= link_to "View", host_event_path(event), class: "text-sm text-stone hover:text-ink transition" %>
    <% end %>

    <% if local_assigns[:management] && own_event %>
      <% if event.active? && event.one_time? && !past %>
        <%= button_to "Cancel", cancel_host_event_path(event), method: :patch,
              data: { turbo_confirm: "Cancel \"#{event.title}\"? This cannot be undone." },
              class: "ml-3 text-sm text-stone hover:text-ember transition cursor-pointer" %>
      <% end %>
      <%= button_to "Delete", host_event_path(event), method: :delete,
            data: { turbo_confirm: "Delete \"#{event.title}\"? This cannot be undone." },
            class: "ml-3 text-sm text-stone hover:text-ember transition cursor-pointer" %>
    <% end %>
  </td>
</tr>
