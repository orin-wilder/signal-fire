<%
  field_class = "w-full px-3 py-2 bg-white border border-stone/40 rounded-lg text-ink focus:outline-none focus:border-ember focus:ring-1 focus:ring-ember transition text-sm"
  label_class = "block text-sm font-medium text-ink mb-1"

  existing_rule = event.recurrence_rule.to_s
  if existing_rule.include?("FREQ=WEEKLY")
    existing_interval = existing_rule.match(/INTERVAL=(\d+)/)&.then { |m| m[1].to_i } || 1
    if existing_interval == 2
      existing_chip = "biweekly"
    elsif existing_interval == 1
      existing_chip = "weekly"
    else
      existing_chip = "custom"
    end
  elsif existing_rule.include?("FREQ=MONTHLY")
    existing_chip = "monthly"
  elsif existing_rule.present?
    existing_chip = "custom"
  else
    existing_chip = "one_time"
  end

  existing_day     = event.start_time&.wday || Time.current.wday
  existing_date    = event.start_time&.to_date&.iso8601 || ""
  existing_start_t = event.start_time&.strftime("%H:%M") || ""
  existing_end_t   = event.end_time&.strftime("%H:%M")   || ""

  monthly_ordinal  = "1"
  monthly_weekday  = "MO"
  monthly_bymonthday = event.start_time&.day || 1
  if existing_rule.include?("BYDAY=") && existing_rule.include?("FREQ=MONTHLY")
    byday_match = existing_rule.match(/BYDAY=(-?\d)([A-Z]{2})/)
    if byday_match
      monthly_ordinal = byday_match[1]
      monthly_weekday = byday_match[2]
    end
  end
  if existing_rule.include?("BYMONTHDAY=")
    monthly_bymonthday = existing_rule.match(/BYMONTHDAY=(\d+)/)[1].to_i rescue monthly_bymonthday
  end

  monthly_subtype = existing_rule.include?("BYMONTHDAY") ? "same_day" : "nth_weekday"

  chip_active   = "bg-ink text-white border-ink"
  chip_inactive = "bg-white text-ink border-stone/30"
%>

<%= form_with model: [:host, event], class: "space-y-0", data: { controller: "event-form" } do |f| %>
  <%# Hidden RRULE input — written by Stimulus %>
  <input type="hidden"
         name="event[recurrence_rule]"
         value="<%= existing_rule %>"
         data-event-form-target="recurrenceInput">

  <% if event.errors.any? %>
    <div class="bg-ember/10 border border-ember/30 rounded-lg p-4 mb-6">
      <p class="text-ember font-medium text-sm mb-1"><%= pluralize(event.errors.count, "error") %> prevented this event from being saved:</p>
      <ul class="list-disc list-inside text-sm text-ember space-y-0.5">
        <% event.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="grid grid-cols-1 lg:grid-cols-2 gap-x-8 gap-y-6">
    <%# ── Left column ── %>
    <div class="space-y-5 min-w-0">
      <%# Title %>
      <div>
        <%= f.label :title, "Title", class: label_class %>
        <%= f.text_field :title,
              required: true,
              placeholder: "e.g. Ecstatic Dance",
              class: field_class %>
      </div>

      <%# Totem %>
      <div>
        <%= f.label :totem_id, "Assigned totem", class: label_class %>
        <%= f.select :totem_id,
              @totems.map { |t| [t.name, t.id] },
              { prompt: "Select a totem" },
              required: true,
              class: field_class %>
      </div>

      <%# Recurrence — 5-chip picker %>
      <fieldset>
        <legend class="<%= label_class %>">Recurrence</legend>
        <div class="flex flex-wrap gap-2">
          <% [
            ["weekly",   "Weekly"],
            ["one_time", "One-time"],
            ["monthly",  "Monthly"],
            ["biweekly", "Every other week"],
            ["custom",   "Custom"],
          ].each do |chip_id, label| %>
            <button type="button"
                    data-event-form-target="chip"
                    data-chip-id="<%= chip_id %>"
                    data-action="click->event-form#selectChip"
                    class="px-4 py-2 text-sm font-medium border rounded-lg transition <%= existing_chip == chip_id ? chip_active : chip_inactive %>">
              <%= label %>
            </button>
          <% end %>
        </div>
      </fieldset>

      <%# Day & time — fields change based on active chip %>
      <div>
        <label class="<%= label_class %>">Day &amp; time</label>
        <div class="space-y-2">

          <%# Day-of-week select (weekly / biweekly) %>
          <div data-event-form-target="weeklyDayField"
               class="<%= %w[weekly biweekly].include?(existing_chip) ? '' : 'hidden' %>">
            <select name="event[start_day_of_week]"
                    data-event-form-target="daySelect"
                    data-action="change->event-form#updateRule"
                    class="<%= field_class %>">
              <% %w[Sunday Monday Tuesday Wednesday Thursday Friday Saturday].each_with_index do |day, i| %>
                <option value="<%= i %>" <%= "selected" if existing_day == i %>><%= day %></option>
              <% end %>
            </select>
          </div>

          <%# Date input (one-time / monthly / custom — not weekly/biweekly) %>
          <div data-event-form-target="oneDateField"
               class="<%= %w[one_time monthly custom].include?(existing_chip) ? '' : 'hidden' %>">
            <p data-event-form-target="customDateHint"
               class="text-xs text-stone mb-1 <%= existing_chip == 'custom' ? '' : 'hidden' %>">
              Starting from (first occurrence of this pattern)
            </p>
            <input type="date"
                   name="event[start_date]"
                   value="<%= existing_date %>"
                   data-event-form-target="dateInput"
                   data-action="change->event-form#updateRule"
                   class="<%= field_class %>"
                   <%= "required" if %w[one_time custom].include?(existing_chip) %>>
          </div>

          <%# Monthly sub-picker %>
          <div data-event-form-target="monthlySubpicker"
               class="<%= existing_chip == 'monthly' ? '' : 'hidden' %> bg-stone/5 border border-stone/20 rounded-lg p-3 space-y-3">
            <label class="flex items-center gap-2 text-sm cursor-pointer">
              <input type="radio"
                     name="_monthly_type"
                     value="same_day"
                     data-event-form-target="monthlyTypeRadio"
                     data-action="change->event-form#updateRule"
                     <%= "checked" if monthly_subtype == "same_day" %>>
              Same day of month (e.g., the <%= monthly_bymonthday.ordinalize %>)
            </label>
            <label class="flex items-center gap-2 text-sm cursor-pointer">
              <input type="radio"
                     name="_monthly_type"
                     value="nth_weekday"
                     data-event-form-target="monthlyTypeRadio"
                     data-action="change->event-form#updateRule"
                     <%= "checked" if monthly_subtype == "nth_weekday" %>>
              Specific weekday of the month
            </label>
            <div data-event-form-target="monthlyNthSelects"
                 class="flex items-center gap-2 pl-6 <%= monthly_subtype == 'nth_weekday' ? '' : 'hidden' %>">
              <select data-event-form-target="monthlyWeekdaySelect"
                      data-action="change->event-form#updateRule"
                      class="<%= field_class %> w-auto">
                <% [["MO","Monday"],["TU","Tuesday"],["WE","Wednesday"],["TH","Thursday"],["FR","Friday"],["SA","Saturday"],["SU","Sunday"]].each do |val, name| %>
                  <option value="<%= val %>" <%= "selected" if monthly_weekday == val %>><%= name %></option>
                <% end %>
              </select>
              <select data-event-form-target="monthlyOrdinalSelect"
                      data-action="change->event-form#updateRule"
                      class="<%= field_class %> w-auto">
                <option value="1"  <%= "selected" if monthly_ordinal == "1"  %>>First</option>
                <option value="2"  <%= "selected" if monthly_ordinal == "2"  %>>Second</option>
                <option value="3"  <%= "selected" if monthly_ordinal == "3"  %>>Third</option>
                <option value="4"  <%= "selected" if monthly_ordinal == "4"  %>>Fourth</option>
                <option value="-1" <%= "selected" if monthly_ordinal == "-1" %>>Last</option>
              </select>
            </div>
          </div>

          <%# Custom RRULE builder %>
          <div data-event-form-target="customBuilder"
               class="<%= existing_chip == 'custom' ? '' : 'hidden' %> bg-stone/5 border border-stone/20 rounded-lg p-3 space-y-3">
            <div class="flex items-center gap-2 text-sm">
              <span class="text-stone">Repeats every</span>
              <input type="number" min="1" max="52" value="1"
                     data-event-form-target="customInterval"
                     data-action="input->event-form#updateRule"
                     class="w-16 px-2 py-1 border border-stone/40 rounded text-sm text-center">
              <select data-event-form-target="customFreq"
                      data-action="change->event-form#updateRule"
                      class="px-2 py-1 border border-stone/40 rounded text-sm">
                <option value="WEEKLY">week(s)</option>
                <option value="MONTHLY">month(s)</option>
              </select>
            </div>
            <div>
              <p class="text-xs text-stone mb-2">On:</p>
              <div class="flex gap-2 flex-wrap">
                <% [["SU","Su"],["MO","Mo"],["TU","Tu"],["WE","We"],["TH","Th"],["FR","Fr"],["SA","Sa"]].each do |val, abbr| %>
                  <label class="flex flex-col items-center gap-1 cursor-pointer">
                    <input type="checkbox"
                           data-event-form-target="customWeekday"
                           data-action="change->event-form#updateRule"
                           value="<%= val %>">
                    <span class="text-xs text-stone"><%= abbr %></span>
                  </label>
                <% end %>
              </div>
            </div>
          </div>

          <%# Start → end time (always visible) %>
          <div class="flex items-center gap-2">
            <input type="time"
                   name="event[start_time_of_day]"
                   value="<%= existing_start_t %>"
                   required
                   class="<%= field_class %> w-36">
            <span class="text-stone text-sm shrink-0">to</span>
            <input type="time"
                   name="event[end_time_of_day]"
                   value="<%= existing_end_t %>"
                   required
                   class="<%= field_class %> w-36">
          </div>
        </div>
      </div>

      <%# Description %>
      <div>
        <%= f.label :description, "Description", class: label_class %>
        <%= f.text_area :description,
              rows: 3,
              placeholder: "Come as you are. We dance for ninety minutes.",
              class: "#{field_class} resize-y" %>
      </div>

      <%# Community norms %>
      <div>
        <%= f.label :community_norms, "Community norms", class: label_class %>
        <p class="text-xs text-stone mb-1">Shown on the event page. Optional.</p>
        <%= f.text_area :community_norms,
              rows: 3,
              placeholder: "• No phones on the floor",
              class: "#{field_class} resize-y" %>
      </div>
    </div>

    <%# ── Right column ── %>
    <div class="space-y-5 min-w-0">
      <%# Group chat %>
      <div>
        <%= f.label :chat_url, "Group chat URL", class: label_class %>
        <%= f.url_field :chat_url, placeholder: "https://...", class: field_class %>
      </div>
    </div>
  </div>

  <%# Actions %>
  <div class="flex items-center gap-3 pt-6 border-t border-stone/20 mt-6">
    <%= f.submit event.new_record? ? "Save event" : "Save changes",
          class: "bg-ember text-white font-semibold px-6 py-2.5 rounded-lg hover:bg-ember/90 active:scale-[0.98] transition cursor-pointer" %>
    <%= link_to "Cancel", host_events_path, class: "text-sm text-stone hover:text-ink transition" %>
  </div>
<% end %>
