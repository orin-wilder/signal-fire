<% content_for :title, "Settings — Signal Fire" %>

<div class="max-w-md">
  <%# ── Profile section ── %>
  <div class="mb-8">
    <p class="font-mono text-[10px] uppercase tracking-widest text-stone mb-1">Settings</p>
    <h1 class="font-serif text-3xl text-ink mb-1">Your host page.</h1>
    <p class="text-stone text-sm">This is how attendees see you.</p>
  </div>

  <% if @host_profile.errors.any? %>
    <div class="bg-ember/10 border border-ember/30 rounded-lg p-4 mb-5">
      <ul class="list-disc list-inside text-sm text-ember space-y-0.5">
        <% @host_profile.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <%= form_with url: host_profile_path, method: :patch, class: "space-y-4 mb-6" do |f| %>
    <div>
      <%= label_tag "profile_display_name", "Display name (shown to attendees)", class: "block text-sm font-medium text-ink mb-1" %>
      <%= text_field_tag "profile[display_name]", @host_profile.display_name,
            id: "profile_display_name",
            class: "w-full px-3 py-2 bg-white border border-stone/40 rounded-lg text-ink focus:outline-none focus:border-ember focus:ring-1 focus:ring-ember transition text-sm" %>
    </div>

    <div>
      <%= label_tag "profile_blurb", "Short blurb (shown on event pages)", class: "block text-sm font-medium text-ink mb-1" %>
      <%= text_area_tag "profile[blurb]", @host_profile.blurb,
            id: "profile_blurb",
            rows: 3,
            placeholder: "A short bio visible to attendees on your event pages.",
            class: "w-full px-3 py-2 bg-white border border-stone/40 rounded-lg text-ink focus:outline-none focus:border-ember focus:ring-1 focus:ring-ember transition text-sm resize-y" %>
    </div>

    <div>
      <%= label_tag "profile_host_story", "Your story", class: "block text-sm font-medium text-ink mb-1" %>
      <%= text_area_tag "profile[host_story]", @host_profile.host_story,
            id: "profile_host_story",
            rows: 4,
            placeholder: "Two sentences works best.",
            class: "w-full px-3 py-2 bg-white border border-stone/40 rounded-lg text-ink focus:outline-none focus:border-ember focus:ring-1 focus:ring-ember transition text-sm resize-y" %>
      <p class="text-xs text-stone/60 mt-1">Shown on your host page and the totem board. Two sentences works best.</p>
    </div>

    <div>
      <label class="block text-sm font-medium text-ink mb-1">Email</label>
      <p class="px-3 py-2 bg-stone/10 border border-stone/20 rounded-lg text-stone text-sm"><%= current_user.email %></p>
      <p class="text-xs text-stone/60 mt-1">Email is tied to your account and can't be changed here.</p>
    </div>

    <%= submit_tag "Save changes",
          class: "bg-ember text-white font-semibold px-6 py-2.5 rounded-lg hover:bg-ember/90 active:scale-[0.98] transition cursor-pointer" %>
  <% end %>

  <hr class="border-stone/20 mb-6">

  <%# ── Account section ── %>
  <div>
    <p class="font-mono text-[10px] uppercase tracking-widest text-stone mb-3">Account</p>

    <div class="border border-stone/20 rounded-xl overflow-hidden divide-y divide-stone/20">
      <%= link_to host_profile_password_path,
            class: "flex items-center justify-between px-4 py-3.5 bg-white/60 hover:bg-white/80 transition text-sm text-ink" do %>
        <span>Change password</span>
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-4 h-4 text-stone/50"><path stroke-linecap="round" stroke-linejoin="round" d="m8.25 4.5 7.5 7.5-7.5 7.5" /></svg>
      <% end %>

      <%= mail_to "Ryan@communityplaytools.com",
            class: "flex items-center justify-between px-4 py-3.5 bg-white/60 hover:bg-white/80 transition text-sm text-ink" do %>
        <span>Email support</span>
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-4 h-4 text-stone/50"><path stroke-linecap="round" stroke-linejoin="round" d="m8.25 4.5 7.5 7.5-7.5 7.5" /></svg>
      <% end %>

      <%= button_to host_logout_path, method: :delete,
            class: "w-full flex items-center justify-between px-4 py-3.5 bg-white/60 hover:bg-white/80 transition text-sm text-ember cursor-pointer" do %>
        <span>Sign out</span>
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-4 h-4 text-ember/50"><path stroke-linecap="round" stroke-linejoin="round" d="m8.25 4.5 7.5 7.5-7.5 7.5" /></svg>
      <% end %>
    </div>
  </div>
</div>
