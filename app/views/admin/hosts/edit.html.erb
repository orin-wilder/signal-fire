<% content_for :title, "Edit #{@host.host_profile&.display_name || @host.name} — Signal Fire Admin" %>

<div class="max-w-lg">
  <p class="text-xs font-mono text-stone/50 uppercase tracking-widest mb-1">Admin · Internal</p>
  <h1 class="font-serif text-3xl text-ink mb-6">Edit host.</h1>

  <%
    field_class = "w-full px-3 py-2 bg-white border border-stone/40 rounded-lg text-ink focus:outline-none focus:border-ember focus:ring-1 focus:ring-ember transition text-sm"
    label_class = "block text-sm font-medium text-ink mb-1"
  %>

  <%= form_with url: admin_host_path(@host), method: :patch, class: "space-y-5" do |f| %>
    <div>
      <label for="host_name" class="<%= label_class %>">Name</label>
      <input type="text" name="host[name]" id="host_name" required
             value="<%= @host.host_profile&.display_name || @host.name %>"
             class="<%= field_class %>">
    </div>

    <div>
      <label for="host_email" class="<%= label_class %>">Email</label>
      <input type="email" name="host[email]" id="host_email" required
             value="<%= @host.email %>"
             class="<%= field_class %>">
    </div>

    <div>
      <label for="host_host_story" class="<%= label_class %>">Host story</label>
      <textarea name="host[host_story]" id="host_host_story" rows="4"
                placeholder="Written by admin at invite time. Host can edit from their profile."
                class="<%= field_class %> resize-y"><%= @host.host_profile&.host_story %></textarea>
      <p class="text-xs text-stone/50 mt-1">Written by admin at invite time. Host can edit from their profile.</p>
    </div>

    <fieldset>
      <legend class="<%= label_class %> mb-2">Assigned totems</legend>
      <% if @all_totems.any? %>
        <div class="space-y-2">
          <%# Hidden field so an empty selection submits totem_ids: [] %>
          <input type="hidden" name="host[totem_ids][]" value="">
          <% @all_totems.each do |totem| %>
            <div class="flex items-center justify-between gap-3">
              <label class="flex items-center gap-2.5 cursor-pointer">
                <input type="checkbox"
                       name="host[totem_ids][]"
                       value="<%= totem.id %>"
                       <%= "checked" if @assigned_totem_ids.include?(totem.id) %>
                       class="rounded border-stone/40 text-ember focus:ring-ember">
                <span class="text-sm text-ink">
                  <%= totem.name %>
                  <span class="text-stone">· <%= totem.location %><%= totem.sublocation.present? ? " · #{totem.sublocation}" : "" %></span>
                </span>
              </label>
              <select name="host[totem_roles][<%= totem.id %>]"
                      class="text-xs border border-stone/40 rounded-lg px-2 py-1 bg-white text-ink focus:outline-none focus:border-ember">
                <% HostTotemAssignment.roles.each_key do |role| %>
                  <option value="<%= role %>"
                    <%= "selected" if (@assigned_roles[totem.id] || "host") == role %>>
                    <%= role.humanize %>
                  </option>
                <% end %>
              </select>
            </div>
          <% end %>
        </div>
      <% else %>
        <p class="text-sm text-stone">No totems exist yet. <%= link_to "Create one", new_admin_totem_path, class: "text-ember hover:underline" %>.</p>
      <% end %>
    </fieldset>

    <div class="flex items-center gap-3 pt-2 border-t border-stone/20">
      <%= f.submit "Save changes",
            class: "bg-ember text-white font-semibold px-5 py-2.5 rounded-lg hover:bg-ember/90 active:scale-[0.98] transition cursor-pointer" %>
      <%= link_to "Cancel", admin_hosts_path, class: "text-sm text-stone hover:text-ink transition" %>
    </div>
  <% end %>
</div>
