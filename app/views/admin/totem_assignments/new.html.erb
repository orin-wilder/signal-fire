<% content_for :title, "Assign a totem role — Signal Fire Admin" %>

<div class="max-w-lg">
  <p class="text-xs font-mono text-stone/50 uppercase tracking-widest mb-1">Admin · Internal</p>
  <h1 class="font-serif text-3xl text-ink mb-6">Assign a totem role.</h1>
  <p class="text-stone text-sm mb-6">Grant any user a per-totem role. Use <strong>totem admin</strong> for delegated
    moderators who don't need a public host profile.</p>

  <%
    field_class = "w-full px-3 py-2 bg-white border border-stone/40 rounded-lg text-ink focus:outline-none focus:border-ember focus:ring-1 focus:ring-ember transition text-sm"
    label_class = "block text-sm font-medium text-ink mb-1"
  %>

  <%= form_with url: admin_totem_assignments_path, method: :post, class: "space-y-5" do %>
    <div>
      <label for="user_id" class="<%= label_class %>">User</label>
      <select name="user_id" id="user_id" required class="<%= field_class %>">
        <% @users.each do |user| %>
          <option value="<%= user.id %>"><%= user.email %><%= " · #{user.name}" if user.name.present? %></option>
        <% end %>
      </select>
    </div>

    <div>
      <label for="totem_id" class="<%= label_class %>">Totem</label>
      <select name="totem_id" id="totem_id" required class="<%= field_class %>">
        <% @totems.each do |totem| %>
          <option value="<%= totem.id %>"><%= totem.name %> · <%= totem.location %></option>
        <% end %>
      </select>
    </div>

    <div>
      <label for="role" class="<%= label_class %>">Role</label>
      <select name="role" id="role" required class="<%= field_class %>">
        <% HostTotemAssignment.roles.each_key do |role| %>
          <option value="<%= role %>"><%= role.humanize %></option>
        <% end %>
      </select>
    </div>

    <div class="flex items-center gap-3 pt-2 border-t border-stone/20">
      <%= submit_tag "Assign role",
            class: "bg-ember text-white font-semibold px-5 py-2.5 rounded-lg hover:bg-ember/90 active:scale-[0.98] transition cursor-pointer" %>
      <%= link_to "Cancel", admin_hosts_path, class: "text-sm text-stone hover:text-ink transition" %>
    </div>
  <% end %>
</div>
