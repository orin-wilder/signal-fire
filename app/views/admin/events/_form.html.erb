<%
  field_class = "w-full px-3 py-2 bg-white border border-stone/40 rounded-lg text-ink focus:outline-none focus:border-ember focus:ring-1 focus:ring-ember transition text-sm"
  label_class = "block text-sm font-medium text-ink mb-1"
  existing_recurrence = event.recurring? ? "weekly" : "one_time"
  existing_day        = event.start_time&.wday || Time.current.wday
  existing_date       = event.start_time&.to_date&.iso8601 || ""
  existing_start_time = event.start_time&.strftime("%H:%M") || ""
  existing_end_time   = event.end_time&.strftime("%H:%M")   || ""
%>

<%= form_with model: [:admin, event],
      class: "space-y-0",
      data: {
        controller: "admin-event-form",
        "admin-event-form-host-totems-value": @host_totems.to_json
      } do |f| %>

  <input type="hidden"
         name="event[recurrence_type]"
         value="<%= existing_recurrence %>"
         data-admin-event-form-target="recurrenceInput">

  <% if event.errors.any? %>
    <div class="bg-ember/10 border border-ember/30 rounded-lg p-4 mb-6">
      <p class="text-ember font-medium text-sm mb-1"><%= pluralize(event.errors.count, "error") %> prevented this event from being saved:</p>
      <ul class="list-disc list-inside text-sm text-ember space-y-0.5">
        <% event.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="grid grid-cols-1 lg:grid-cols-2 gap-x-8 gap-y-6">
    <%# ── Left column ── %>
    <div class="space-y-5 min-w-0">

      <%# Host selector %>
      <div>
        <label for="event_host_user_id" class="<%= label_class %>">Host</label>
        <select name="event[host_user_id]"
                id="event_host_user_id"
                required
                data-admin-event-form-target="hostSelect"
                data-action="change->admin-event-form#hostChanged"
                class="<%= field_class %>">
          <option value="">Select a host</option>
          <% @hosts.each do |host| %>
            <option value="<%= host.id %>" <%= "selected" if event.host_user_id == host.id %>>
              <%= host.host_profile&.display_name || host.name %>
            </option>
          <% end %>
        </select>
      </div>

      <%# Title %>
      <div>
        <%= f.label :title, "Title", class: label_class %>
        <%= f.text_field :title,
              required: true,
              placeholder: "e.g. Ecstatic Dance",
              class: field_class %>
      </div>

      <%# Totem — populated by Stimulus based on host selection %>
      <div>
        <label for="event_totem_id" class="<%= label_class %>">Totem</label>
        <select name="event[totem_id]"
                id="event_totem_id"
                required
                data-admin-event-form-target="totemSelect"
                data-current="<%= event.totem_id %>"
                class="<%= field_class %>">
          <option value="">Select a totem</option>
        </select>
      </div>

      <%# Event type toggle %>
      <fieldset>
        <legend class="<%= label_class %>">Event type</legend>
        <div class="flex rounded-lg overflow-hidden border border-stone/30 w-fit">
          <button type="button"
                  data-admin-event-form-target="recurringBtn"
                  data-action="click->admin-event-form#selectRecurring"
                  class="px-5 py-2 text-sm font-medium transition <%= existing_recurrence == 'weekly' ? 'bg-ember text-white' : 'bg-white text-ink border-r border-stone/30' %>">
            Recurring · weekly
          </button>
          <button type="button"
                  data-admin-event-form-target="oneTimeBtn"
                  data-action="click->admin-event-form#selectOneTime"
                  class="px-5 py-2 text-sm font-medium transition <%= existing_recurrence == 'one_time' ? 'bg-ember text-white' : 'bg-white text-ink' %>">
            One-time
          </button>
        </div>
      </fieldset>

      <%# Day & time %>
      <div>
        <label class="<%= label_class %>">Day &amp; time</label>
        <div class="space-y-2">
          <div data-admin-event-form-target="weeklyDayField" class="<%= existing_recurrence == 'one_time' ? 'hidden' : '' %>">
            <select name="event[start_day_of_week]" class="<%= field_class %>">
              <% %w[Sunday Monday Tuesday Wednesday Thursday Friday Saturday].each_with_index do |day, i| %>
                <option value="<%= i %>" <%= "selected" if existing_day == i %>><%= day %></option>
              <% end %>
            </select>
          </div>

          <div data-admin-event-form-target="oneDateField" class="<%= existing_recurrence == 'weekly' ? 'hidden' : '' %>">
            <input type="date"
                   name="event[start_date]"
                   value="<%= existing_date %>"
                   class="<%= field_class %>"
                   <%= "required" if existing_recurrence == "one_time" %>>
          </div>

          <div class="flex items-center gap-2">
            <input type="time"
                   name="event[start_time_of_day]"
                   value="<%= existing_start_time %>"
                   required
                   class="<%= field_class %> w-36">
            <span class="text-stone text-sm shrink-0">to</span>
            <input type="time"
                   name="event[end_time_of_day]"
                   value="<%= existing_end_time %>"
                   required
                   class="<%= field_class %> w-36">
          </div>
        </div>
      </div>

      <%# Description %>
      <div>
        <%= f.label :description, "Description", class: label_class %>
        <%= f.text_area :description,
              rows: 3,
              placeholder: "Come as you are. We dance for ninety minutes.",
              class: "#{field_class} resize-y" %>
      </div>

      <%# Community norms %>
      <div>
        <%= f.label :community_norms, "Community norms", class: label_class %>
        <p class="text-xs text-stone mb-1">Shown on the event page. Optional.</p>
        <%= f.text_area :community_norms,
              rows: 3,
              placeholder: "• No phones on the floor",
              class: "#{field_class} resize-y" %>
      </div>
    </div>

    <%# ── Right column ── %>
    <div class="space-y-5 min-w-0">
      <%# Group chat %>
      <div>
        <%= f.label :chat_url, "Group chat URL", class: label_class %>
        <%= f.url_field :chat_url, placeholder: "https://...", class: field_class %>
      </div>

      <%# Optional source link (1D) %>
      <div>
        <%= f.label :source_url, "Add a link (optional)", class: label_class %>
        <p class="text-xs text-stone mb-1">A page with more info. Shown as a small “More info” link on the board.</p>
        <%= f.url_field :source_url, placeholder: "https://...", class: field_class %>
      </div>

      <div class="bg-stone/5 border border-stone/20 rounded-xl p-4 text-sm text-stone">
        <p class="font-medium text-ink mb-1">Admin override.</p>
        <p>This event will show the selected host's name publicly. The admin-created flag is stored in DB for reporting only.</p>
      </div>
    </div>
  </div>

  <div class="flex items-center gap-3 pt-6 border-t border-stone/20 mt-6">
    <%= f.submit event.new_record? ? "Create event" : "Save changes",
          class: "bg-ember text-white font-semibold px-6 py-2.5 rounded-lg hover:bg-ember/90 active:scale-[0.98] transition cursor-pointer" %>
    <%= link_to "Cancel", admin_events_path, class: "text-sm text-stone hover:text-ink transition" %>
  </div>
<% end %>
