<%
  field_class = "w-full px-3 py-2 bg-white border border-stone/40 rounded-lg text-ink focus:outline-none focus:border-ember focus:ring-1 focus:ring-ember transition text-sm"
  label_class = "block text-sm font-medium text-ink mb-1"
  eastern     = post.starts_at&.in_time_zone("America/New_York")
%>

<%= form_with model: [:admin, post], class: "space-y-5 max-w-lg" do |f| %>
  <% if post.errors.any? %>
    <div class="bg-ember/10 border border-ember/30 rounded-lg p-4">
      <p class="text-ember font-medium text-sm mb-1"><%= pluralize(post.errors.count, "error") %> prevented this post from being saved:</p>
      <ul class="list-disc list-inside text-sm text-ember space-y-0.5">
        <% post.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div>
    <p class="<%= label_class %>">Totem</p>
    <p class="text-sm text-stone"><%= post.totem.name %></p>
  </div>

  <div>
    <%= f.label :title, "Event name", class: label_class %>
    <%= f.text_field :title, required: true, maxlength: 80, class: field_class %>
  </div>

  <div class="flex gap-3">
    <div class="flex-1">
      <%= f.label :date, "Date", class: label_class %>
      <%= f.date_field :date, value: eastern&.strftime("%Y-%m-%d"), required: true, class: field_class %>
    </div>
    <div class="flex-1">
      <%= f.label :time, "Time", class: label_class %>
      <%= f.time_field :time, value: eastern&.strftime("%H:%M"), required: true, class: field_class %>
    </div>
  </div>

  <div>
    <%= f.label :description, "Description", class: label_class %>
    <%= f.text_field :description, required: true, maxlength: 160, class: field_class %>
  </div>

  <fieldset>
    <legend class="<%= label_class %>">Recurring</legend>
    <label class="flex items-center gap-2 cursor-pointer mb-2">
      <%= f.check_box :recurring, class: "rounded border-stone/40 text-ember focus:ring-ember" %>
      <span class="text-sm text-ink">This happens regularly</span>
    </label>
    <%= f.label :recurrence_cadence, "Frequency", class: "text-xs text-stone mb-1 block" %>
    <%= f.select :recurrence_cadence,
          options_for_select([["Weekly", "weekly"], ["Monthly", "monthly"]], post.recurrence_cadence),
          {}, class: field_class %>
    <p class="text-xs text-stone mt-1">Frequency is ignored unless “happens regularly” is checked.</p>
  </fieldset>

  <div class="flex items-center gap-3 pt-2 border-t border-stone/20">
    <%= f.submit "Save changes",
          class: "bg-ember text-white font-semibold px-5 py-2.5 rounded-lg hover:bg-ember/90 active:scale-[0.98] transition cursor-pointer" %>
    <%= link_to "Cancel", admin_bulletin_posts_path, class: "text-sm text-stone hover:text-ink transition" %>
  </div>
<% end %>
