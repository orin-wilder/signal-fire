<% content_for :title, "Edit #{@totem.name} — Signal Fire Admin" %>

<div class="max-w-lg">
  <p class="text-xs font-mono text-stone/50 uppercase tracking-widest mb-1">Admin · Internal</p>
  <h1 class="font-serif text-3xl text-ink mb-6">Edit totem.</h1>
  <%= render "form", totem: @totem %>

  <div class="mt-8 pt-6 border-t border-stone/20">
    <p class="text-xs font-mono text-stone/50 uppercase tracking-widest mb-2">Bulletin board</p>
    <p class="text-sm text-stone mb-2">Public board for the paint-stick sign. Print the QR or share the link.</p>
    <div class="flex items-center gap-3">
      <%= link_to bulletin_board_url(@totem.slug), target: "_blank", rel: "noopener",
            class: "text-sm text-ink underline break-all" do %>
        <%= bulletin_board_url(@totem.slug) %>
      <% end %>
    </div>
    <%= link_to "Download board QR", board_qr_admin_totem_path(@totem),
          class: "inline-block mt-3 bg-ember text-white text-sm font-semibold px-4 py-2 rounded-lg hover:bg-ember/90 transition" %>
  </div>
</div>
