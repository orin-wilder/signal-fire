<!DOCTYPE html>
<html lang="en">
  <head>
    <title><%= content_for(:title) || "Signal Fire — Host Dashboard" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Instrument+Sans:ital,wght@0,400..700;1,400..700&family=Instrument+Serif:ital@0;1&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">

    <%= stylesheet_link_tag "tailwind", "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="bg-paper text-ink">
    <header class="border-b border-stone/20" data-controller="sidebar">
      <div class="px-6 py-4 flex items-center justify-between">
        <%= link_to host_dashboard_path, class: "flex items-center gap-2.5" do %>
          <span class="w-2 h-2 rounded-full bg-ember flex-shrink-0"></span>
          <span class="font-serif text-lg text-ink">Signal Fire</span>
          <span class="hidden sm:inline font-mono text-[10px] text-stone/50 uppercase tracking-widest">Host Dashboard</span>
        <% end %>

        <%# Desktop nav %>
        <nav class="hidden md:flex items-center gap-6">
          <%= link_to "Dashboard", host_dashboard_path,
                class: "text-sm transition #{request.path == host_dashboard_path ? 'font-semibold text-ink' : 'text-stone hover:text-ink'}" %>
          <%= link_to "Events", host_events_path,
                class: "text-sm transition #{request.path.start_with?('/host/events') ? 'font-semibold text-ink' : 'text-stone hover:text-ink'}" %>
          <%= link_to "Insights", host_events_path,
                class: "text-sm transition #{request.path.start_with?('/host/insights') ? 'font-semibold text-ink' : 'text-stone hover:text-ink'}" %>
          <%= link_to "Totems", host_totems_path,
                class: "text-sm transition #{request.path.start_with?('/host/totems') ? 'font-semibold text-ink' : 'text-stone hover:text-ink'}" %>
          <%= link_to "Settings", host_profile_path,
                class: "text-sm transition #{request.path.start_with?('/host/profile') ? 'font-semibold text-ink' : 'text-stone hover:text-ink'}" %>
        </nav>

        <%# Mobile hamburger %>
        <button data-action="click->sidebar#toggle" class="md:hidden text-stone p-1" aria-label="Open menu">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none"
               stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <line x1="3" y1="6" x2="21" y2="6"/>
            <line x1="3" y1="12" x2="21" y2="12"/>
            <line x1="3" y1="18" x2="21" y2="18"/>
          </svg>
        </button>
      </div>

      <%# Mobile dropdown menu %>
      <div data-sidebar-target="drawer" class="hidden md:hidden border-t border-stone/20 px-6 py-5 flex flex-col gap-5">
        <%= link_to "Dashboard", host_dashboard_path,
              class: "text-sm #{request.path == host_dashboard_path ? 'font-semibold text-ink' : 'text-stone hover:text-ink'}",
              data: { action: "click->sidebar#close" } %>
        <%= link_to "Events", host_events_path,
              class: "text-sm #{request.path.start_with?('/host/events') ? 'font-semibold text-ink' : 'text-stone hover:text-ink'}",
              data: { action: "click->sidebar#close" } %>
        <%= link_to "Insights", host_events_path,
              class: "text-sm #{request.path.start_with?('/host/insights') ? 'font-semibold text-ink' : 'text-stone hover:text-ink'}",
              data: { action: "click->sidebar#close" } %>
        <%= link_to "Totems", host_totems_path,
              class: "text-sm #{request.path.start_with?('/host/totems') ? 'font-semibold text-ink' : 'text-stone hover:text-ink'}",
              data: { action: "click->sidebar#close" } %>
        <%= link_to "Settings", host_profile_path,
              class: "text-sm #{request.path.start_with?('/host/profile') ? 'font-semibold text-ink' : 'text-stone hover:text-ink'}",
              data: { action: "click->sidebar#close" } %>
      </div>
    </header>

    <% if flash[:notice] %>
      <div class="bg-glen text-ink text-sm font-medium px-6 py-3" role="alert">
        <%= flash[:notice] %>
      </div>
    <% end %>
    <% if flash[:alert] %>
      <div class="bg-ember text-white text-sm font-medium px-6 py-3" role="alert">
        <%= flash[:alert] %>
      </div>
    <% end %>

    <main class="px-5 md:px-8 py-8">
      <%= yield %>
    </main>
  </body>
</html>
