<!DOCTYPE html>
<html lang="en">
  <head>
    <title><%= content_for(:title) || "Signal Fire Board" %></title>
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover">
    <meta name="theme-color" content="#F5F1ED">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=DM+Mono:wght@400;500&family=Instrument+Serif:ital@0;1&display=swap" rel="stylesheet">

    <%= javascript_importmap_tags %>

    <style>
      /* ── Civic Beacon · standalone board surface (isolated from app theme) ── */
      :root {
        --ink: #1A1714;
        --paper: #F5F1ED;
        --paper-2: #ECE7DD;
        --ember: #DA5520;
        --stone: #898581;
        --line: rgba(26, 23, 20, 0.14);
        --serif: "Instrument Serif", Georgia, serif;
        --mono: "DM Mono", ui-monospace, monospace;
        --sans: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
      }

      * { box-sizing: border-box; }

      html, body {
        margin: 0;
        padding: 0;
        background: var(--paper);
        color: var(--ink);
        font-family: var(--sans);
        font-size: 16px;
        line-height: 1.5;
        -webkit-text-size-adjust: 100%;
      }

      .bb-wrap {
        max-width: 480px;
        margin: 0 auto;
        padding: 32px 20px 120px;
      }

      .bb-kicker {
        font-family: var(--mono);
        font-size: 11px;
        letter-spacing: 0.14em;
        text-transform: uppercase;
        color: var(--stone);
      }

      /* ── Masthead ── */
      .bb-location {
        font-family: var(--serif);
        font-weight: 400;
        font-size: 40px;
        line-height: 1.05;
        margin: 6px 0 10px;
        color: var(--ink);
      }
      .bb-sub {
        color: var(--ink);
        font-size: 16px;
        margin: 0;
      }

      /* ── Primary Ember CTA ── */
      .bb-cta {
        display: block;
        width: 100%;
        min-height: 52px;
        margin: 24px 0 8px;
        padding: 15px 20px;
        background: var(--ember);
        color: #fff;
        font-family: var(--mono);
        font-size: 14px;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        text-align: center;
        border: none;
        border-radius: 2px;
        cursor: pointer;
      }
      .bb-cta:active { transform: translateY(1px); }
      .bb-cta[hidden] { display: none; }

      /* sticky bottom repeat on mobile */
      .bb-cta-sticky {
        position: fixed;
        left: 0; right: 0; bottom: 0;
        z-index: 20;
        margin: 0;
        border-radius: 0;
        max-width: 480px;
        margin: 0 auto;
        box-shadow: 0 -1px 0 var(--line);
      }
      @media (min-width: 481px) {
        .bb-cta-sticky { display: none; }
      }

      /* ── Section kicker + trailing hairline ── */
      .bb-section {
        display: flex;
        align-items: center;
        gap: 12px;
        margin: 36px 0 4px;
      }
      .bb-section .bb-kicker { color: var(--ink); white-space: nowrap; }
      .bb-section .bb-rule { flex: 1; height: 1px; background: var(--line); }

      /* ── Event rows ── */
      .bb-rows { list-style: none; margin: 0; padding: 0; }
      .bb-row { padding: 20px 0; border-bottom: 1px solid var(--line); }
      .bb-title {
        font-family: var(--serif);
        font-weight: 400;
        font-size: 24px;
        line-height: 1.1;
        color: var(--ink);
        margin: 0 0 6px;
      }
      .bb-meta {
        font-family: var(--mono);
        font-size: 12px;
        letter-spacing: 0.1em;
        text-transform: uppercase;
        color: var(--ink);
      }
      .bb-desc {
        color: var(--stone);
        font-size: 15px;
        margin: 6px 0 0;
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
      }
      .bb-badge {
        display: inline-block;
        margin-left: 8px;
        padding: 2px 7px;
        font-family: var(--mono);
        font-size: 10px;
        letter-spacing: 0.12em;
        color: var(--ink);
        background: var(--paper);
        border: 1px solid var(--ink);
        border-radius: 2px;
        vertical-align: middle;
      }

      /* ── Earlier divider ── */
      .bb-earlier {
        display: flex;
        align-items: center;
        gap: 12px;
        margin: 36px 0 4px;
      }
      .bb-earlier .bb-rule { flex: 1; height: 1px; background: var(--line); }
      .bb-earlier .bb-kicker { color: var(--stone); }

      /* ── Past rows — all Stone, smaller, lighter ── */
      .bb-row-past { padding: 14px 0; border-bottom: 1px solid var(--line); }
      .bb-row-past .bb-title {
        font-size: 20px;
        color: var(--stone);
      }
      .bb-row-past .bb-meta { color: var(--stone); font-size: 11px; }
      .bb-row-past .bb-desc { color: var(--stone); }

      /* ── Empty state ── */
      .bb-empty-title {
        font-family: var(--serif);
        font-size: 26px;
        margin: 32px 0 8px;
      }
      .bb-empty-body { color: var(--stone); margin: 0; }

      /* ── Board directory rows (link-wrapped) ── */
      .bb-board-link { display: block; text-decoration: none; color: inherit; }
      .bb-board-link .bb-arrow {
        font-family: var(--mono);
        color: var(--ember);
        margin-left: 8px;
        font-size: 18px;
        vertical-align: baseline;
      }

      /* ── "See other boards" link ── */
      .bb-otherboards {
        display: block;
        text-align: center;
        margin: 28px 0 0;
        font-family: var(--mono);
        font-size: 12px;
        letter-spacing: 0.1em;
        text-transform: uppercase;
        color: var(--ink);
        text-decoration: underline;
      }

      /* ── Footer ── */
      .bb-footer {
        margin-top: 48px;
        padding-top: 20px;
        border-top: 1px solid var(--line);
        font-family: var(--mono);
        font-size: 11px;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        color: var(--stone);
      }

      /* ── Submit panel ── */
      .bb-panel {
        margin: 8px 0 0;
        padding: 20px;
        background: var(--paper-2);
        border: 1px solid var(--line);
        border-radius: 3px;
      }
      .bb-panel[hidden] { display: none; }
      .bb-panel-heading {
        font-family: var(--serif);
        font-size: 24px;
        margin: 0 0 16px;
      }
      .bb-field { margin-bottom: 16px; }
      .bb-label {
        display: block;
        font-family: var(--mono);
        font-size: 11px;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        color: var(--stone);
        margin-bottom: 6px;
      }
      .bb-input {
        width: 100%;
        min-height: 44px;
        padding: 11px 12px;
        font-size: 16px;
        font-family: var(--sans);
        color: var(--ink);
        background: var(--paper);
        border: 1px solid var(--line);
        border-radius: 2px;
      }
      .bb-input:focus { outline: 2px solid var(--ink); outline-offset: -1px; }
      .bb-row-2 { display: flex; gap: 12px; }
      .bb-row-2 .bb-field { flex: 1; }

      .bb-check { display: flex; align-items: center; gap: 10px; cursor: pointer; }
      .bb-check input { width: 20px; height: 20px; accent-color: var(--ink); }
      .bb-check span { font-size: 16px; }

      /* segmented Weekly/Monthly toggle — Ink selection, never Ember */
      .bb-segmented { display: flex; border: 1px solid var(--ink); border-radius: 2px; overflow: hidden; margin-top: 4px; }
      .bb-segmented label {
        flex: 1;
        min-height: 44px;
        display: flex; align-items: center; justify-content: center;
        font-family: var(--mono);
        font-size: 12px;
        letter-spacing: 0.1em;
        text-transform: uppercase;
        color: var(--ink);
        cursor: pointer;
        background: var(--paper);
      }
      .bb-segmented label + label { border-left: 1px solid var(--ink); }
      .bb-segmented input { position: absolute; opacity: 0; pointer-events: none; }
      .bb-segmented input:checked + span,
      .bb-segmented label:has(input:checked) { background: var(--ink); color: var(--paper); }

      .bb-cadence[hidden] { display: none; }

      /* in-form submit — Ink (Ember budget spent on board CTA) */
      .bb-submit {
        display: block;
        width: 100%;
        min-height: 48px;
        margin-top: 8px;
        padding: 13px;
        background: var(--ink);
        color: var(--paper);
        font-family: var(--mono);
        font-size: 14px;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        border: none;
        border-radius: 2px;
        cursor: pointer;
      }
      .bb-helper { color: var(--stone); font-size: 14px; margin: 12px 0 0; }
      .bb-error { color: var(--ink); font-size: 14px; margin: 4px 0 0; font-style: italic; }

      /* success */
      .bb-success-title { font-family: var(--serif); font-size: 26px; margin: 0 0 8px; }
      .bb-success-body { color: var(--stone); margin: 0 0 16px; }
      .bb-textbtn {
        background: none; border: none; padding: 0;
        color: var(--ink); text-decoration: underline;
        font-size: 16px; font-family: var(--sans); cursor: pointer;
      }
    </style>
  </head>

  <body>
    <div class="bb-wrap">
      <%= yield %>
    </div>
  </body>
</html>
