<% content_for :title, @totem.name %>

<div class="min-h-screen bg-[#f2f0d9]" data-controller="app-nudge<%= ' account-signup' unless app_nudges_enabled? || signed_in? %>">
  <header class="px-4 pt-8 pb-6">
    <div class="flex items-start justify-between gap-3">
      <div class="flex-1 min-w-0">
        <p class="font-mono text-xs tracking-widest text-[#867a60] uppercase mb-1">Totem</p>
        <h1 class="font-serif text-3xl text-[#1a1a12]"><%= @totem.name %></h1>
        <% if @totem.character_description.present? %>
          <p class="mt-2 text-sm text-[#867a60] leading-relaxed"><%= @totem.character_description %></p>
        <% end %>
      </div>
      <% if current_user %>
        <button
          data-controller="totem-favorite"
          data-totem-favorite-totem-id-value="<%= @totem.id %>"
          data-totem-favorite-favorite-id-value="<%= @favorite&.id.to_s %>"
          data-totem-favorite-favorited-value="<%= @favorite.present? %>"
          data-action="click->totem-favorite#toggle"
          aria-label="<%= @favorite ? 'Remove from favorites' : 'Add to favorites' %>"
          aria-pressed="<%= @favorite.present? %>"
          class="mt-1 shrink-0 p-1.5 rounded-md hover:bg-[#f0ede0] transition-colors star-toggle">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24"
               fill="<%= @favorite ? '#1a1a12' : 'none' %>"
               stroke="#1a1a12" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"
               aria-hidden="true">
            <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/>
          </svg>
        </button>
      <% end %>
    </div>
  </header>

  <main class="px-4 pb-24 space-y-8">
    <%# ── Add an event: prominent CTA that opens the inline submission panel ── %>
    <section data-controller="event-submission" aria-label="Add an event">
      <button type="button"
              data-event-submission-target="cta"
              data-action="event-submission#open"
              class="w-full bg-[#e24820] hover:bg-[#c43a18] text-white font-semibold rounded-xl px-4 py-3.5 transition-colors">
        + Add an event here
      </button>
      <div data-event-submission-target="panel" hidden
           class="bg-white border border-[#867a60]/30 rounded-xl p-5 mt-3">
        <div id="event-submission-form">
          <%= render "totems/event_submissions/form", totem: @totem, event: @event %>
        </div>
      </div>
    </section>

    <% if @active_now.any? %>
      <%= render "active_now_section", events: @active_now %>
    <% end %>

    <% if @upcoming.any? %>
      <%= render "upcoming_section", events: @upcoming %>
    <% end %>

    <% if @active_now.empty? && @upcoming.empty? %>
      <p class="text-center text-[#867a60] py-6 text-sm">Nothing scheduled here yet — be the first to add something.</p>
    <% end %>

    <%# ── Notify-me email capture (only on a genuinely empty board) ── %>
    <% if @board_empty %>
      <div class="border-t border-[#867a60]/20 pt-8">
        <p class="font-mono text-xs tracking-widest text-[#867a60] uppercase mb-2">Get notified when it lights up</p>
        <p class="text-sm text-[#867a60] mb-4">Drop your email and we'll let you know the first time a group posts here.</p>

        <%= form_with url: empty_totem_email_captures_path, method: :post, class: "space-y-3" do |f| %>
          <%= hidden_field_tag :totem_id, @totem.id %>
          <%= label_tag :email, "Email address", class: "sr-only" %>
          <%= email_field_tag :email, nil,
                placeholder: "you@email.com", required: true, autocomplete: "email",
                class: "w-full border border-[#867a60]/40 bg-white rounded-lg px-4 py-3 text-[#1a1a12] placeholder-[#867a60]/60 focus:outline-none focus:ring-2 focus:ring-[#e24820] focus:border-transparent" %>
          <%= submit_tag "Notify me",
                class: "w-full bg-[#e24820] hover:bg-[#c43a18] text-white font-medium rounded-lg px-4 py-3 cursor-pointer transition-colors" %>
        <% end %>
      </div>
    <% end %>

    <% if @past.any? %>
      <%= render "past_section", events: @past, totem: @totem %>
    <% end %>

    <%# Host story panel — taps through to host page %>
    <% if @host&.host_profile&.host_story.present? %>
      <%= link_to host_page_path(@host.host_profile.slug) do %>
        <div class="bg-[#fdf6f0] border border-[#e8d5c4] rounded-xl p-5">
          <div class="flex items-center justify-between mb-3">
            <p class="font-mono text-xs tracking-widest text-[#da5520] uppercase">Meet your host</p>
            <p class="font-mono text-xs tracking-widest text-[#da5520] uppercase">See all events →</p>
          </div>
          <p class="text-sm text-[#1a1a12] leading-relaxed"><%= @host.host_profile.host_story %></p>
        </div>
      <% end %>
    <% elsif @host.present? %>
      <div class="bg-[#f7f5ee] border border-[#d6d0c4] rounded-xl p-5">
        <p class="text-sm text-[#867a60]">Meet your host — coming soon</p>
      </div>
    <% end %>

    <%= render "shared/nearby_carousel", events: @nearby, heading: "Other places nearby" %>
  </main>

  <footer class="px-4 pb-6 text-center text-xs text-[#867a60] space-x-3">
    <%= link_to "Request a group", "mailto:hello@signalfire.live", class: "underline hover:text-[#1a1a12]" %>
    <span>·</span>
    <%= link_to "Send feedback", "mailto:ryan@communityplaytools.com", class: "underline hover:text-[#1a1a12]" %>
  </footer>

  <% if app_nudges_enabled? && !@footer_dismissed %>
    <%= render "footer_nudge" %>
  <% end %>

  <% if app_nudges_enabled? %>
    <%= render "shared/app_download_nudge" %>
  <% end %>

  <% unless app_nudges_enabled? || signed_in? %>
    <%= render "shared/account_signup_modal" %>
    <%= render "shared/account_signup_banner" %>
  <% end %>
</div>
