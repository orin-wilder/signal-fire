<%# locals: totem, event %>
<% input = "w-full px-3 py-2 bg-white border border-stone/30 rounded-lg text-sm text-ink placeholder:text-stone/50 focus:outline-none focus:border-ember focus:ring-1 focus:ring-ember transition" %>
<% label = "block text-sm font-medium text-ink mb-1" %>
<% error = "text-ember text-xs mt-1" %>

<%= form_with url: totem_event_submissions_path(totem.slug),
              method: :post, scope: :event,
              data: { turbo: true, controller: "event-submission event-photo",
                      event_photo_url_value: totem_event_from_photo_path(totem.slug) } do |f| %>

  <h2 class="font-serif text-xl text-ink mb-4">Add an event</h2>

  <%# Shortcut: upload a flyer photo or a screenshot and let AI prefill the
      fields below. No `capture` attribute, so this opens the photo library
      (with Files as a fallback) rather than forcing the camera. %>
  <div class="mb-4">
    <button type="button" data-action="event-photo#choose"
            class="w-full flex items-center justify-center gap-2 border border-stone/30 text-ink text-sm font-medium rounded-lg px-4 py-2.5 hover:border-ink transition">
      <span aria-hidden="true">🖼️</span> Upload a photo or screenshot
    </button>
    <input type="file" accept="image/*" class="hidden"
           data-event-photo-target="input" data-action="change->event-photo#upload">
    <p class="text-xs text-stone mt-1" data-event-photo-target="status" aria-live="polite"></p>
  </div>

  <% if event.errors[:base].any? %>
    <p class="<%= error %> mb-3"><%= event.errors[:base].first %></p>
  <% end %>

  <div class="mb-4">
    <%= f.label :title, "Event name", class: label %>
    <%= f.text_field :title, value: event.title, class: input, required: true,
          placeholder: "Sunset yoga, pickup soccer, porch concert…" %>
    <% if event.errors[:title].any? %><p class="<%= error %>"><%= event.errors[:title].first %></p><% end %>
  </div>

  <div class="grid grid-cols-2 gap-3 mb-1">
    <div>
      <%= f.label :date, "Date", class: label %>
      <%= f.date_field :date,
            value: event.start_time&.in_time_zone("America/New_York")&.strftime("%Y-%m-%d"),
            class: input, required: true %>
    </div>
    <div>
      <%= f.label :time, "Time", class: label %>
      <%= f.time_field :time,
            value: event.start_time&.in_time_zone("America/New_York")&.strftime("%H:%M"),
            class: input, required: true %>
    </div>
  </div>
  <% if event.errors[:start_time].any? %><p class="<%= error %> mb-3"><%= event.errors[:start_time].first %></p><% end %>
  <div class="mb-4"></div>

  <div class="mb-4">
    <%= f.label :short_description, "Description", class: label %>
    <%= f.text_field :short_description, value: event.short_description, class: input,
          placeholder: "One line — what should folks know?" %>
    <% if event.errors[:short_description].any? %><p class="<%= error %>"><%= event.errors[:short_description].first %></p><% end %>
  </div>

  <div class="mb-4">
    <label class="flex items-center gap-2 text-sm text-ink">
      <%= f.check_box :recurring, checked: event.recurring?,
            data: { event_submission_target: "recurring", action: "change->event-submission#toggleCadence" },
            class: "rounded border-stone/40 text-ember focus:ring-ember" %>
      <span>This happens regularly</span>
    </label>

    <div class="mt-3 <%= "hidden" unless event.recurring? %>" data-event-submission-target="cadence">
      <%= f.label :recurrence_cadence, "Frequency", class: label %>
      <% cadence = event.weekly? ? "weekly" : (event.recurring? ? "monthly" : "weekly") %>
      <div class="inline-flex gap-4 text-sm text-ink">
        <label class="flex items-center gap-1.5">
          <%= f.radio_button :recurrence_cadence, "weekly", checked: cadence == "weekly", class: "text-ember focus:ring-ember" %>
          <span>Weekly</span>
        </label>
        <label class="flex items-center gap-1.5">
          <%= f.radio_button :recurrence_cadence, "monthly", checked: cadence == "monthly", class: "text-ember focus:ring-ember" %>
          <span>Monthly</span>
        </label>
      </div>
    </div>
  </div>

  <div class="mb-4">
    <%= f.label :source_url, "Link (optional)", class: label %>
    <%= f.url_field :source_url, value: event.source_url, class: input,
          placeholder: "https://… a page with more info" %>
    <% if event.errors[:source_url].any? %><p class="<%= error %>"><%= event.errors[:source_url].first %></p><% end %>
  </div>

  <% unless current_user&.can_auto_publish_on?(totem) %>
    <div class="mb-4">
      <%= f.label :submitter_email, "Email (optional)", class: label %>
      <%= f.email_field :submitter_email, value: event.submitter_email, class: input,
            placeholder: "We'll let you know when it's approved" %>
      <% if event.errors[:submitter_email].any? %><p class="<%= error %>"><%= event.errors[:submitter_email].first %></p><% end %>
    </div>
  <% end %>

  <%= f.submit "Put it on the board",
        class: "w-full bg-ember text-white font-semibold px-4 py-2.5 rounded-lg hover:bg-ember/90 transition" %>

  <% unless current_user&.can_auto_publish_on?(totem) %>
    <p class="text-stone text-xs mt-3 text-center">No account needed. A person reviews every post before it shows up.</p>
  <% end %>
<% end %>
