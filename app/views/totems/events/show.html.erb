<% content_for :title, "#{@event.title} · #{@totem.name}" %>

<div class="min-h-screen bg-[#f2f0d9]">
  <header class="px-4 pt-6 pb-4 border-b border-[#867a60]/20">
    <%= link_to "‹ Back to board", totem_board_path(@totem.slug),
          class: "inline-flex items-center text-sm text-[#867a60] mb-4" %>

    <% if @event.cancelled? %>
      <%= render "cancelled_banner" %>
    <% else %>
      <%= render "window_chip", state: @window_state %>
    <% end %>

    <h1 class="font-serif text-2xl text-[#1a1a12] leading-tight mt-2"><%= @event.title %></h1>

    <p class="mt-2 text-sm text-[#867a60]">
      <% occurrence = @event.next_occurrence %>
      <% if @event.recurring? %>
        <%= @event.recurrence_label %> · <%= occurrence.strftime("%-I:%M %p") %> – <%= @event.end_time.strftime("%-I:%M %p") %>
      <% else %>
        <%= occurrence.strftime("%A · %B %-d · %-I:%M %p") %>
      <% end %>
    </p>

    <p class="text-sm text-[#867a60] mt-0.5">
      <%= @totem.name %><% if @totem.location.present? %> · <%= @totem.location %><% if @totem.sublocation.present? %> · <%= @totem.sublocation %><% end %><% end %>
    </p>
  </header>

  <main class="px-4 pt-6 pb-48 space-y-6">
    <%# Inline Follow host row (§6.4) %>
    <% if @host_profile %>
      <section class="flex items-start justify-between gap-4">
        <div>
          <p class="font-mono text-xs tracking-widest text-[#867a60] uppercase mb-1">Host</p>
          <%= link_to @host_profile.slug.present? ? host_page_path(@host_profile.slug) : "#",
                class: "font-semibold text-[#1a1a12] hover:underline" do %>
            <%= @host_profile.display_name %>
          <% end %>
          <% if @host_profile.blurb.present? %>
            <p class="text-sm text-[#867a60] mt-0.5"><%= @host_profile.blurb %></p>
          <% end %>
        </div>
        <% if current_user %>
          <%= button_to @host_follow ? "Following" : "+ Follow",
                @host_follow ? host_follow_path(@host_follow) : host_follows_path,
                method: @host_follow ? :delete : :post,
                params: @host_follow ? {} : { host_user_id: @event.host_user_id },
                class: "shrink-0 text-sm font-medium px-4 py-2 rounded-lg border transition #{@host_follow ? 'bg-[#1a1a12] text-white border-[#1a1a12]' : 'bg-transparent text-[#1a1a12] border-[#867a60]/40 hover:border-[#1a1a12]'}" %>
        <% else %>
          <%= link_to "+ Follow", sign_in_path,
                class: "shrink-0 text-sm font-medium px-4 py-2 rounded-lg border border-[#867a60]/40 text-[#1a1a12] hover:border-[#1a1a12] transition" %>
        <% end %>
      </section>
    <% end %>

    <% if @event.description.present? %>
      <section>
        <h2 class="font-mono text-xs tracking-widest text-[#867a60] uppercase mb-2">Description</h2>
        <p class="text-[#1a1a12] leading-relaxed"><%= @event.description %></p>
      </section>
    <% end %>

    <% if @event.community_norms.present? %>
      <%= render "community_norms", norms: @event.community_norms %>
    <% end %>
  </main>

  <div class="fixed bottom-0 inset-x-0 bg-[#f2f0d9] border-t border-[#867a60]/20 px-4 py-4 space-y-3">
    <% if [:starting_soon, :happening_now, :just_ended].include?(@window_state) %>
      <%= render "check_in_button", event: @event, totem: @totem %>
    <% end %>

    <% if @event.chat_url.present? %>
      <%= render "join_chat_button", event: @event %>
    <% end %>

    <%# Save to calendar (§6.2) %>
    <% unless @event.cancelled? %>
      <%= link_to "Save to my calendar",
            event_calendar_path(@totem.slug, @event.slug),
            class: "block w-full text-center border border-[#867a60]/40 text-[#1a1a12] font-medium rounded-lg px-4 py-3 bg-transparent hover:border-[#1a1a12] transition" %>
    <% end %>

    <%# Share event (§6.3) %>
    <button data-controller="share"
            data-share-url-value="<%= request.original_url %>"
            data-share-title-value="<%= @event.title %>"
            data-share-event-id-value="<%= @event.id %>"
            data-action="click->share#share"
            class="block w-full text-center border border-[#867a60]/40 text-[#1a1a12] font-medium rounded-lg px-4 py-3 bg-transparent hover:border-[#1a1a12] transition">
      Share this event
    </button>
  </div>
</div>
