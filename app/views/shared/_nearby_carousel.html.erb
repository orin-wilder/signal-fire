<%# Horizontally scrollable strip of upcoming events at other totems. %>
<%# Server-rendered + native scroll (no JS framework). Stone/ink only — no ember. %>
<% events ||= [] %>
<% if events.size >= 2 %>
  <section class="mt-10">
    <p class="font-mono text-[10px] tracking-widest text-[#867a60] uppercase mb-3"><%= heading %></p>
    <div class="flex gap-3 overflow-x-auto pb-2 -mx-4 px-4 snap-x snap-mandatory">
      <% events.each do |event| %>
        <%= link_to totem_board_path(event.totem.slug),
              class: "snap-start shrink-0 w-56 rounded-xl border border-[#867a60]/30 bg-white p-4 hover:border-[#867a60] transition-colors",
              data: { analytics: "nearby_carousel_clicked", totem_slug: event.totem.slug } do %>
          <p class="font-mono text-[10px] tracking-widest text-[#867a60] uppercase truncate"><%= event.totem.name %></p>
          <h3 class="font-medium text-[#1a1a12] mt-1 line-clamp-2"><%= event.title %></h3>
          <p class="text-sm text-[#867a60] mt-1">
            <%= city_board_event_day_label(event) %> · <%= event.next_occurrence.strftime("%-I:%M %p") %>
          </p>
        <% end %>
      <% end %>
    </div>
  </section>
<% end %>
