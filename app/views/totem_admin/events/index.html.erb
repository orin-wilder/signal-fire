<% content_for :title, "Review queue — Signal Fire" %>

<div class="mb-6">
  <p class="text-xs font-mono text-stone/50 uppercase tracking-widest mb-1">Totem Admin</p>
  <h1 class="font-serif text-3xl text-ink">Review queue.</h1>
  <p class="text-stone text-sm mt-1">Submissions waiting for your OK on the totems you moderate.</p>
</div>

<% if @events.any? %>
  <div class="space-y-3">
    <% @events.each do |event| %>
      <div class="bg-white/60 border border-stone/20 rounded-xl px-5 py-4">
        <div class="flex items-start justify-between gap-4 flex-wrap">
          <div class="min-w-0">
            <p class="font-medium text-ink"><%= event.title %></p>
            <p class="text-sm text-stone mt-0.5">
              <%= event.totem.name %> · <%= event.start_time.strftime("%a, %b %-d · %-I:%M %p") %>
              <% if event.recurring? %> · <%= event.recurrence_label %><% end %>
            </p>
            <% if event.short_description.present? %>
              <p class="text-sm text-stone mt-1"><%= event.short_description %></p>
            <% end %>
            <% if event.source_url.present? %>
              <%= link_to "Source ↗", event.source_url, target: "_blank", rel: "noopener",
                    class: "text-ember text-xs font-medium hover:underline mt-1 inline-block" %>
            <% end %>
          </div>
          <div class="flex items-center gap-2 shrink-0">
            <%= button_to "Publish", publish_totem_admin_event_path(event), method: :patch,
                  class: "bg-ember text-white text-sm font-semibold px-3 py-1.5 rounded-lg hover:bg-ember/90 transition" %>
            <%= link_to "Edit", edit_totem_admin_event_path(event),
                  class: "text-sm text-stone hover:text-ink transition px-2 py-1.5" %>
            <%= button_to "Remove", totem_admin_event_path(event), method: :delete,
                  form: { data: { turbo_confirm: "Remove this submission?" } },
                  class: "text-sm text-stone hover:text-ember transition px-2 py-1.5" %>
          </div>
        </div>
      </div>
    <% end %>
  </div>
<% else %>
  <div class="border border-dashed border-stone/30 rounded-xl p-10 text-center">
    <p class="text-stone text-sm">Nothing waiting for review.</p>
  </div>
<% end %>
