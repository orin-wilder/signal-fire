<%# locals: totem, post %>
<h2 class="bb-panel-heading">Add an event</h2>

<%= form_with url: bulletin_board_posts_path(totem.slug),
              method: :post,
              scope: :bulletin_post,
              data: { turbo: true } do |f| %>

  <div class="bb-field">
    <%= f.label :title, "Event name", class: "bb-label" %>
    <%= f.text_field :title,
          value: post.title,
          class: "bb-input",
          placeholder: "Sunset yoga, pickup soccer, porch concert…",
          required: true %>
    <% if post.errors[:title].any? %>
      <p class="bb-error"><%= post.errors[:title].first %></p>
    <% end %>
  </div>

  <div class="bb-row-2">
    <div class="bb-field">
      <%= f.label :date, "Date", class: "bb-label" %>
      <%= f.date_field :date,
            value: post.starts_at&.in_time_zone("America/New_York")&.strftime("%Y-%m-%d"),
            class: "bb-input",
            required: true %>
    </div>
    <div class="bb-field">
      <%= f.label :time, "Time", class: "bb-label" %>
      <%= f.time_field :time,
            value: post.starts_at&.in_time_zone("America/New_York")&.strftime("%H:%M"),
            class: "bb-input",
            required: true %>
    </div>
  </div>
  <% if post.errors[:starts_at].any? %>
    <p class="bb-error" style="margin-top:-8px;margin-bottom:12px;"><%= post.errors[:starts_at].first %></p>
  <% end %>

  <div class="bb-field">
    <%= f.label :description, "Description", class: "bb-label" %>
    <%= f.text_field :description,
          value: post.description,
          class: "bb-input",
          placeholder: "One line — what should folks know?" %>
    <% if post.errors[:description].any? %>
      <p class="bb-error"><%= post.errors[:description].first %></p>
    <% end %>
  </div>

  <div class="bb-field">
    <label class="bb-check">
      <%= f.check_box :recurring,
            checked: post.recurring,
            data: { bulletin_board_target: "recurring", action: "change->bulletin-board#toggleCadence" } %>
      <span>This happens regularly</span>
    </label>

    <div class="bb-cadence" <%= "hidden" unless post.recurring %> data-bulletin-board-target="cadence" style="margin-top:12px;">
      <%= f.label :recurrence_cadence, "Frequency", class: "bb-label" %>
      <div class="bb-segmented">
        <% cadence = post.recurrence_cadence.presence || "weekly" %>
        <label>
          <%= f.radio_button :recurrence_cadence, "weekly", checked: cadence == "weekly" %>
          <span>Weekly</span>
        </label>
        <label>
          <%= f.radio_button :recurrence_cadence, "monthly", checked: cadence == "monthly" %>
          <span>Monthly</span>
        </label>
      </div>
      <% if post.errors[:recurrence_cadence].any? %>
        <p class="bb-error"><%= post.errors[:recurrence_cadence].first %></p>
      <% end %>
    </div>
  </div>

  <div class="bb-field">
    <%= f.label :source_url, "Link (optional)", class: "bb-label" %>
    <%= f.url_field :source_url,
          value: post.source_url,
          class: "bb-input",
          placeholder: "https://… a page with more info" %>
    <% if post.errors[:source_url].any? %>
      <p class="bb-error"><%= post.errors[:source_url].first %></p>
    <% end %>
  </div>

  <%= f.submit "Put it on the board", class: "bb-submit" %>

  <p class="bb-helper">No account, no email. A person reviews every post before it shows up.</p>
<% end %>
