<%# locals: boards — totems with an upcoming approved post, excluding the current one. %>
<% if boards.any? %>
  <div class="bb-section" style="margin-bottom:0;">
    <span class="bb-kicker">OTHER BOARDS NEARBY</span>
    <span class="bb-rule"></span>
  </div>

  <div class="bb-boards-scroll">
    <% boards.each do |board| %>
      <% next_post = board.bulletin_posts.upcoming.first %>
      <%= link_to bulletin_board_path(board.slug), class: "bb-board-tile" do %>
        <p class="bb-board-name"><%= board.name %></p>
        <% if next_post %>
          <p class="bb-board-meta"><%= bulletin_when(next_post.starts_at, dotted_day: false) %></p>
          <p class="bb-board-title"><%= next_post.title %></p>
        <% end %>
      <% end %>
    <% end %>
  </div>

  <%= link_to "See all boards", bulletin_boards_directory_path, class: "bb-otherboards" %>
<% end %>
