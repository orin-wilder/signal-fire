# Local development environment. Copy to .env (bin/setup does this automatically).
# dotenv-rails loads .env in development and test, so these reach the app and the
# pg driver (libpq) without any changes to config/database.yml.

# Postgres connection — matches the postgres service in compose.yml.
PGHOST=localhost
PGPORT=5432
PGUSER=postgres
PGPASSWORD=postgres

# PostHog analytics. Leave blank locally; analytics are disabled when unset.
POSTHOG_PROJECT_TOKEN=
